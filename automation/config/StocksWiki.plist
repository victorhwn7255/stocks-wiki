<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Shows in System Settings → Login Items & Extensions → Allow in the Background. -->
    <key>Label</key>
    <string>Stocks Wiki</string>

    <!-- The autonomous self-X loop: a free deterministic scan every night, plus Max-subscription
         agentic work 6 nights/week (Mon = calibration scoring + ranked briefing; Tue-Sat = one
         deep-research topic; Sun = scan only). The agentic steps run `claude -p` under the user's
         logged-in Claude Max subscription (NOT API billing), behind the locked tool allow-list
         (discovery-only, writes only to automation/ + raw/research/self-research/). -->
    <!-- Run the app-bundle launcher (not python3 directly) so macOS displays this background
         item as "Stocks Wiki". The launcher exec()s `run.py --auto --quiet` (--auto picks the
         day's work per the schedule above); env below flows through. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/victor_he/Applications/Stocks Wiki.app/Contents/MacOS/Stocks Wiki</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/victor_he/Projects/stocks-wiki</string>

    <!-- launchd has a minimal PATH with no `claude`; supply the node bin + CLAUDE_BIN + HOME
         so the Max-authenticated CLI is found and can read its stored credentials. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/victor_he/.nvm/versions/node/v22.22.0/bin:/Library/Frameworks/Python.framework/Versions/3.13/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>CLAUDE_BIN</key>
        <string>/Users/victor_he/.nvm/versions/node/v22.22.0/bin/claude</string>
        <key>HOME</key>
        <string>/Users/victor_he</string>
    </dict>

    <!-- Daily 03:30 local (Singapore, UTC+8). --auto runs a free deterministic scan every day;
         the Max agentic work runs 6 nights/week (deep-research Tue-Sat, calibration + briefing
         Mon), Sunday is scan-only. On a deep-research night the loop rides through a 5-hour usage
         cap (waits for reset, then continues) but hard-stops at 06:00. NOTE: if the Mac is asleep
         at 03:30, launchd runs the job at the next wake. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>3</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/victor_he/Projects/stocks-wiki/automation/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/victor_he/Projects/stocks-wiki/automation/logs/launchd.err.log</string>

    <!-- Wait for the scheduled time; do not fire on every login (each agentic run uses Max usage). -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
